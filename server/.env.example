# Copy this file to .env and fill in your values.
# Never commit .env to version control.

PORT=3000

# PostgreSQL connection string.
# On Railway this is provided automatically as DATABASE_URL when you add a
# Postgres service — you don't need to set it manually in production.
# For local development, create a local Postgres database and paste its URL here.
DATABASE_URL=postgresql://user:password@localhost:5432/manuka_registrations

# ── SMTP ──────────────────────────────────────────────────────
# Gmail example — enable 2-factor auth on your Google account, then create
# an App Password at myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your-16-char-app-password

# The address emails are sent from (must match SMTP_USER for Gmail)
SENDER_EMAIL=your@gmail.com
SENDER_DISPLAY_NAME=Manuka Honey Gentell Education Team

# Address that receives a notification for each new registration
ORGANISER_EMAIL=organiser@example.com

# Location text shown in confirmation emails for in-person sessions
SESSION_LOCATION=Venue details will be confirmed separately.

# ── Per-session joining links (Teams / Zoom URLs) ─────────────
JOINING_LINK_15_JULY=
JOINING_LINK_21_JULY=
JOINING_LINK_23_JULY=

# ── Per-session times (e.g. "10:00 AM – 12:00 PM BST") ───────
SESSION_TIME_15_JULY=Time to be confirmed
SESSION_TIME_21_JULY=Time to be confirmed
SESSION_TIME_23_JULY=Time to be confirmed
